<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
--bg:#0a0a0a;--surface:#111;--border:rgba(255,255,255,0.08);
--accent:#C6F135;--text:#f0f0f0;--muted:#888;--card:#161616;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-weight:300;line-height:1.6;overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.2rem 2.5rem;display:flex;justify-content:space-between;align-items:center;background:rgba(10,10,10,0.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;letter-spacing:-0.02em;display:flex;align-items:center;gap:0.5rem;text-decoration:none;color:var(--text)}
.logo .accent-dot{color:var(--accent)}
.dot{width:8px;height:8px;background:var(--accent);border-radius:50%;display:inline-block}
.nav-right{display:flex;align-items:center;gap:1.5rem}
.nav-links{display:flex;gap:1.5rem;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:0.82rem;letter-spacing:0.05em;text-transform:uppercase;transition:color .2s}
.nav-links a:hover{color:var(--text)}
.nav-links a.active{color:var(--accent)}
.nav-socials{display:flex;gap:0.75rem;align-items:center}
.nav-socials a{color:var(--muted);display:flex;align-items:center;transition:color .2s}
.nav-socials a:hover{color:var(--accent)}
.btn{padding:0.6rem 1.4rem;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:500;cursor:pointer;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:0.4rem}
.btn-primary{background:var(--accent);color:#000;border:none}
.btn-primary:hover{background:#aad62e;transform:translateY(-2px)}
.btn-ghost{background:transparent;color:var(--text);border:1px solid var(--border)}
.btn-ghost:hover{border-color:rgba(255,255,255,0.25);transform:translateY(-2px)}

/* HERO (home, full height) */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:8rem 2.5rem 4rem;position:relative;overflow:hidden}
.glow1{position:absolute;top:-200px;right:-150px;width:600px;height:600px;background:radial-gradient(circle,rgba(198,241,53,0.07) 0%,transparent 70%);pointer-events:none}
.glow2{position:absolute;bottom:-100px;left:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(255,77,109,0.05) 0%,transparent 70%);pointer-events:none}
.badge{display:inline-flex;align-items:center;gap:0.5rem;border:1px solid var(--border);background:var(--surface);padding:0.3rem 0.85rem;border-radius:999px;font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:1.75rem;width:fit-content}
.blink{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:blink 1.5s infinite}
h1{font-family:'Syne',sans-serif;font-size:clamp(2.6rem,7vw,5.5rem);font-weight:800;line-height:1;letter-spacing:-0.04em}
h1 span{display:block;color:var(--muted)}
.sub{margin-top:1.5rem;font-size:1rem;color:var(--muted);max-width:460px}
.cta{margin-top:2rem;display:flex;gap:1rem;flex-wrap:wrap}

/* PAGE HERO (sub-pages, shorter) */
.page-hero{padding:9rem 2.5rem 3rem;position:relative;overflow:hidden}
.page-hero h2{margin-bottom:0}
.page-hero .sub{max-width:560px;margin-top:1rem}

/* STATS */
.stats{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:1.5rem 2.5rem;display:flex;gap:3rem;overflow-x:auto}
.stat-num{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800}
.stat-lbl{font-size:0.72rem;color:var(--muted);letter-spacing:0.05em}

/* SECTIONS */
section{padding:5rem 2.5rem}
.label{font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--accent);margin-bottom:0.75rem;font-weight:500}
h2{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:700;letter-spacing:-0.03em;line-height:1.1;margin-bottom:2.5rem}

/* GRID / CARDS (products) */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem}
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.75rem;position:relative;transition:border-color .25s,transform .25s}
.card:hover{border-color:rgba(198,241,53,0.25);transform:translateY(-4px)}
.card-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:1.1rem}
.y{background:rgba(198,241,53,0.1)} .r{background:rgba(255,77,109,0.1)} .b{background:rgba(77,150,255,0.1)}
.card-title{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:0.4rem}
.card-desc{font-size:0.83rem;color:var(--muted);line-height:1.6}
.tag{display:inline-block;padding:0.18rem 0.65rem;border-radius:999px;font-size:0.68rem;letter-spacing:0.05em;text-transform:uppercase;border:1px solid var(--border);color:var(--muted)}
.card-footer{display:flex;align-items:center;justify-content:space-between;margin-top:1rem;flex-wrap:wrap;gap:0.5rem}
.product-actions{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:1rem}
.view-btn{display:inline-flex;align-items:center;gap:0.35rem;padding:0.35rem 0.85rem;border-radius:6px;font-size:0.75rem;font-weight:500;text-decoration:none;border:1px solid var(--border);color:var(--muted);transition:all .2s;background:transparent}
.view-btn:hover{border-color:rgba(198,241,53,0.4);color:var(--accent);transform:translateY(-1px)}
.play-tri{width:0;height:0;border-top:4px solid transparent;border-bottom:4px solid transparent;border-left:6px solid currentColor;flex-shrink:0}
.demo-btn:hover{background:rgba(198,241,53,0.06)}
.card-dashed{border-style:dashed;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.4rem;min-height:160px;color:var(--muted);font-size:0.85rem}
.card-dashed span{font-size:1.3rem}

/* HUB CARDS (home -> 4 pages) */
.hub-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem}
.hub-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.9rem;text-decoration:none;color:var(--text);display:block;position:relative;transition:border-color .25s,transform .25s}
.hub-card:hover{border-color:rgba(198,241,53,0.3);transform:translateY(-4px)}
.hub-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1.1rem;margin-top:1rem;margin-bottom:0.4rem}
.hub-desc{font-size:0.83rem;color:var(--muted);line-height:1.6}
.hub-arrow{position:absolute;top:1.5rem;right:1.5rem;color:var(--muted);font-size:1rem;transition:color .2s,transform .2s}
.hub-card:hover .hub-arrow{color:var(--accent);transform:translate(2px,-2px)}

/* SERVICE BLOCKS (ai solutions) */
.service-block{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:2.25rem;margin-bottom:1.25rem;display:grid;grid-template-columns:auto 1fr auto;gap:1.75rem;align-items:start}
.service-block h3{font-family:'Syne',sans-serif;font-weight:700;font-size:1.3rem;margin-bottom:.6rem}
.service-block .desc{color:var(--muted);font-size:0.92rem;line-height:1.75;margin-bottom:1.1rem;max-width:560px}
.service-list{list-style:none;display:flex;flex-wrap:wrap;gap:.5rem}
.service-list li{font-size:.76rem;color:var(--text);background:var(--surface);border:1px solid var(--border);padding:.35rem .8rem;border-radius:999px}
.service-block .card-icon{width:52px;height:52px;font-size:1.4rem;margin-bottom:0}
@media(max-width:768px){.service-block{grid-template-columns:1fr}}

/* DEMO DECK */
.channels{border-top:1px solid var(--border)}
.channel{display:grid;grid-template-columns:48px 1fr auto;align-items:center;gap:1.5rem;padding:1.6rem 0.25rem;border-bottom:1px solid var(--border);cursor:pointer;transition:background .25s;text-decoration:none;color:var(--text)}
.channel:hover{background:rgba(198,241,53,0.04)}
.channel-num{font-family:'Syne',sans-serif;font-size:.8rem;color:var(--muted)}
.channel-mid{display:flex;align-items:center;gap:1.1rem;min-width:0}
.channel-play{width:44px;height:44px;border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:border-color .25s,background .25s}
.channel:hover .channel-play{border-color:var(--accent);background:rgba(198,241,53,0.1)}
.channel-play .play-tri{border-left-color:var(--text)}
.channel:hover .channel-play .play-tri{border-left-color:var(--accent)}
.channel-title{font-family:'Syne',sans-serif;font-weight:700;font-size:1.05rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.channel-watch{font-family:'Syne',sans-serif;font-weight:600;font-size:.78rem;color:var(--muted);display:flex;align-items:center;gap:.4rem;white-space:nowrap;transition:color .25s,gap .25s}
.channel:hover .channel-watch{color:var(--text);gap:.65rem}
@media(max-width:640px){.channel{grid-template-columns:36px 1fr}.channel-watch{grid-column:2/3}}

/* INTENT BUTTONS (contact) */
.intent-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;margin:2.5rem 0}
.intent-btn{display:block;background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.5rem;text-decoration:none;color:var(--text);transition:border-color .25s,transform .25s;text-align:left}
.intent-btn:hover{border-color:rgba(198,241,53,0.35);transform:translateY(-3px)}
.intent-btn .t{font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;margin-bottom:.3rem}
.intent-btn .d{font-size:.8rem;color:var(--muted)}
.big-email{display:block;font-family:'Syne',sans-serif;font-weight:800;font-size:clamp(1.5rem,5vw,2.6rem);color:var(--text);text-decoration:none;letter-spacing:-0.02em;word-break:break-word;transition:color .2s}
.big-email:hover{color:var(--accent)}

/* ABOUT */
.about-wrap{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.about-text p{color:var(--muted);font-size:0.92rem;line-height:1.8;margin-bottom:0.9rem}
.chips{display:flex;flex-wrap:wrap;gap:0.45rem;margin-top:1.25rem}
.chip{padding:0.3rem 0.85rem;background:var(--surface);border:1px solid var(--border);border-radius:999px;font-size:0.76rem;color:var(--text);transition:border-color .2s,color .2s}
.chip:hover{border-color:rgba(198,241,53,0.4);color:var(--accent)}

/* CONTACT PANEL (reused as closing CTA on every page) */
.contact-wrap{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:4rem;text-align:center;position:relative;overflow:hidden}
.contact-wrap::before{content:'';position:absolute;top:-120px;left:50%;transform:translateX(-50%);width:400px;height:250px;background:radial-gradient(ellipse,rgba(198,241,53,0.07) 0%,transparent 70%);pointer-events:none}
.contact-wrap h2{margin-bottom:0.75rem}
.contact-wrap p{color:var(--muted);font-size:0.92rem;margin-bottom:1.75rem}
.email-link{font-family:'Syne',sans-serif;font-size:1rem;color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(198,241,53,0.3);padding-bottom:2px}
.socials{display:flex;justify-content:center;gap:0.75rem;margin-top:1.75rem;flex-wrap:wrap}
.slink{display:inline-flex;align-items:center;gap:0.4rem;padding:0.45rem 1rem;border:1px solid var(--border);border-radius:8px;color:var(--muted);text-decoration:none;font-size:0.8rem;transition:all .2s}
.slink:hover{border-color:rgba(198,241,53,0.3);color:var(--accent);transform:translateY(-2px)}

/* FOOTER */
footer{padding:1.75rem 2.5rem;display:flex;justify-content:space-between;align-items:center;color:var(--muted);font-size:0.78rem;border-top:1px solid var(--border);flex-wrap:wrap;gap:.5rem}

@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}

@media(max-width:768px){
.about-wrap{grid-template-columns:1fr}
.contact-wrap{padding:2.5rem 1.5rem}
nav{padding:1rem 1.25rem}
.nav-links,.nav-socials{display:none}
section{padding:3.5rem 1.25rem}
.page-hero{padding:7.5rem 1.25rem 2.5rem}
.stats{padding:1.25rem;gap:1.5rem}
h1{font-size:clamp(2.3rem,11vw,3.6rem)}
}
</style>
</head>
